# ─────────────────────────────────────────────────────────────────────────────
# MonFrigo — Variables d'environnement pour déploiement Vercel
# Copier ce fichier, remplir chaque valeur, puis les ajouter dans
# Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentification JWT ─────────────────────────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacer_par_une_chaine_aleatoire_de_48_caracteres_minimum

# ── Base de données PostgreSQL ───────────────────────────────────────────────
# Créer un compte sur https://neon.tech → New project → Connection string (pooler)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Intelligence artificielle (Groq — GRATUIT) ──────────────────────────────
# Créer un compte sur https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=remplacer_par_votre_cle_groq

# ── Stripe (paiements) ──────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=remplacer_par_votre_cle_stripe

# Webhook secret — obtenu APRÈS avoir créé le webhook dans Stripe dashboard
# Stripe → Developers → Webhooks → Add endpoint → https://<app>.vercel.app/api/stripe/webhook
# Événements : customer.subscription.created, customer.subscription.updated,
#              customer.subscription.deleted, checkout.session.completed
STRIPE_WEBHOOK_SECRET=remplacer_par_votre_webhook_secret

# ── Optionnel ────────────────────────────────────────────────────────────────
# NODE_ENV est automatiquement mis à "production" par Vercel
# LOG_LEVEL=info
