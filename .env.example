# ─────────────────────────────────────────────────────────────────────────────
# MonFrigo — Variables d'environnement pour déploiement Vercel
# Copier ce fichier, remplir chaque valeur, puis les ajouter dans
# Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk (authentification) ────────────────────────────────────────────────
# Créer un compte sur https://clerk.com → New application → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Clerk proxy (optionnel) — décommenter APRÈS le premier déploiement
# Remplacer <VOTRE_APP> par votre URL Vercel réelle (ex: monfrigo.vercel.app)
# VITE_CLERK_PROXY_URL=https://<VOTRE_APP>.vercel.app/api/__clerk

# ── Base de données PostgreSQL ───────────────────────────────────────────────
# Créer un compte sur https://neon.tech → New project → Connection string (pooler)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Intelligence artificielle (Groq — GRATUIT) ──────────────────────────────
# Créer un compte sur https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Stripe (paiements) ──────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret — obtenu APRÈS avoir créé le webhook dans Stripe dashboard
# Stripe → Developers → Webhooks → Add endpoint → https://<app>.vercel.app/api/stripe/webhook
# Événements : customer.subscription.created, customer.subscription.updated,
#              customer.subscription.deleted, checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Optionnel ────────────────────────────────────────────────────────────────
# NODE_ENV est automatiquement mis à "production" par Vercel
# LOG_LEVEL=info
